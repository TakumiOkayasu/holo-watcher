# GitHub Webhook Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# /api/notify Bearer Token
NOTIFY_API_TOKEN=your_notify_api_token_here

# GitHub Token (optional: for fetching failed job/step details + webhook sync)
# Fine-grained PAT: actions:read, administration:write
GITHUB_TOKEN=github_pat_xxxxx

# Webhook sync target URL (optional: for /api/sync-webhooks)
WEBHOOK_URL=https://workers.example.com/webhook

# Allowed GitHub Owner/Org (optional, comma-separated)
ALLOWED_OWNER=your_github_owner_here
